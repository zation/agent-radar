# Copy to .env and replace the values needed by your local workflow. Never commit .env.
AGENT_RADAR_LLM_API_KEY=replace-with-provider-key
AGENT_RADAR_LLM_MODEL=replace-with-provider-model
AGENT_RADAR_LLM_BASE_URL=replace-with-provider-base-url

GITHUB_OAUTH_CLIENT_ID=replace-with-development-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=replace-with-development-oauth-client-secret
AGENT_RADAR_SESSION_SECRET=replace-with-at-least-32-random-bytes
AGENT_RADAR_RELEASE_ID=local-v0.4
AGENT_RADAR_API_VERSION=local
AGENT_RADAR_WEB_VERSION=local
