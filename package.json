{
  "name": "agent-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist public/data public/reports",
    "dev": "npm run dev:data && npm run pages:build && npm run dev:db && concurrently --kill-others-on-fail --names api,ui \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:data": "npm run build && node dist/src/cli/ensure-dev-data.js",
    "dev:api": "wrangler dev --local --port 8787 --env-file .env",
    "dev:db": "CI=1 wrangler d1 migrations apply agent-radar --local",
    "dev:ui": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:server": "npm run dev:ui",
    "dev:empty": "npm run dev:ui",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "pages:build": "vite build",
    "dev:with-data": "npm run dev",
    "release:build": "npm test && npm run pipeline && npm run release:check && npm run pages:build",
    "preview:finalize": "npm run build && node dist/src/cli/finalize-preview.js",
    "preview:build": "npm run release:build && npm run preview:finalize",
    "test": "npm run build && node --test dist/tests/*.test.js && node dist/src/cli/check-public-language.js",
    "language:check": "npm run build && node dist/src/cli/check-public-language.js",
    "pipeline": "npm run build && node dist/src/cli/build-artifacts.js",
    "ingest": "npm run build && node dist/src/cli/run-ingest.js",
    "promotion:check": "npm run build && node dist/src/cli/check-promotion-candidates.js",
    "release:check": "npm run build && node dist/src/cli/check-eval-summary.js",
    "data-quality:check": "npm run build && node dist/src/cli/check-data-quality.js",
    "review-summary:check": "npm run build && node dist/src/cli/check-review-summary.js",
    "mcp:smoke": "npm run build && node dist/src/cli/run-mcp-smoke.js",
    "eval": "npm run build && node dist/src/cli/run-eval.js",
    "feedback:prepare": "npm run build && node dist/src/cli/prepare-feedback.js",
    "feedback:apply": "npm run build && node dist/src/cli/apply-feedback-plan.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.3"
  }
}
